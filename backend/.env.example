PORT=3001
NODE_ENV=development
FRONTEND_ORIGIN=http://localhost:5173

# Oracle — credentials never commit .env
# ORACLE_HOST = server IP or hostname ONLY (do not include :1521 here)
ORACLE_HOST=
ORACLE_PORT=1521
# ORACLE_SERVICE = Oracle service name / PDB (e.g. uatpdb.ysg.com)
ORACLE_SERVICE=
ORACLE_USER=
ORACLE_PASSWORD=

# View + scope (all from env, nothing hardcoded in code)
ORACLE_VIEW_NAME=OV_PO_SEARCH_VIEW_YSG
ORACLE_COMP_CODE=YSG
ORACLE_TXN_CODE=PO
ORACLE_APPLY_COMP_TXN_FILTER=true

# Scale: pool per app instance (run multiple instances behind load balancer)
ORACLE_POOL_MIN=4
ORACLE_POOL_MAX=50
ORACLE_POOL_INCREMENT=4
ORACLE_CONNECT_TIMEOUT=30

# Column names for generic query builder (change per module if needed)
ORACLE_ID_COLUMN=DOC_NO
ORACLE_DATE_COLUMN=DOC_DT

# System defaults (exposed via GET /api/po/system-defaults)
ORACLE_DEFAULT_CURRENCY=THB
ORACLE_SEARCH_LIMIT=20
ORACLE_ITEM_SEARCH_LIMIT=30
ORACLE_MIN_SEARCH_CHARS=2
ORACLE_LOOKUP_DEBOUNCE_MS=300

# ORACLE form config view (optional)
ORACLE_FORM_CONFIG_VIEW=

# ─────────────────────────────────────────────────────
# PENDING: Set these when DB team delivers view names
# ─────────────────────────────────────────────────────
ORACLE_SUPPLIER_VIEW=        # e.g. OV_SUPPLIER_YSG
ORACLE_ITEM_VIEW=            # e.g. OV_ITEM_YSG (source: OM_ITEM)
ORACLE_ITEM_VALIDATE_SP=     # e.g. o_dval_item_11j
ORACLE_LOCATION_VIEW=        # e.g. OV_LOCATION_YSG
ORACLE_PAYMENT_TERM_VIEW=    # e.g. OV_PAY_TERM_YSG
ORACLE_PO_LINE_VIEW=         # e.g. OV_PO_ITEM_YSG

# ─────────────────────────────────────────────────────
# PENDING: Set these when DB team delivers SP names
# ─────────────────────────────────────────────────────
ORACLE_PO_CREATE_SP=         # e.g. SP_PO_CREATE_YSG
ORACLE_PO_UPDATE_SP=         # e.g. SP_PO_UPDATE_YSG
ORACLE_PO_APPROVE_SP=        # e.g. SP_PO_APPROVE_YSG

# ─────────────────────────────────────────────────────
# FUTURE (next sprint)
# ─────────────────────────────────────────────────────
ORACLE_PO_DUPLICATE_SP=      # Future — duplicate PO feature

# PO line view — DOC_NO column for filtering lines by order
ORACLE_PO_LINE_DOC_COL=DOC_NO

# Lookup column overrides (defaults match typical Oracle naming)
ORACLE_SUPPLIER_CODE_COL=SUPP_CODE
ORACLE_SUPPLIER_NAME_COL=SUPP_NAME
ORACLE_SUPPLIER_ADDR_COL=SUPP_ADDR
ORACLE_SUPPLIER_SHIP_MODE_COL=SHIP_MODE
ORACLE_SUPPLIER_PAY_TERM_COL=PAY_TERM
ORACLE_SUPPLIER_DOC_LOCN_COL=DOC_LOCN
ORACLE_ITEM_CODE_COL=ITEM_CODE
ORACLE_ITEM_NAME_COL=ITEM_NAME
ORACLE_ITEM_UOM_COL=UOM
ORACLE_LOCATION_CODE_COL=LOCN_CODE
ORACLE_LOCATION_NAME_COL=LOCN_NAME
ORACLE_PAYMENT_TERM_CODE_COL=TERM_CODE
ORACLE_PAYMENT_TERM_NAME_COL=TERM_NAME
ORACLE_PAYMENT_TERM_SUPP_COL=SUPP_CODE
