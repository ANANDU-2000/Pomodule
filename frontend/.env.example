# Backend must be running on port 3001 when VITE_MOCK_MODE=false (Vite proxies /api → localhost:3001)
VITE_API_BASE_URL=

# false = real Oracle via backend (default). true = frontend-only mock dev without VPN/backend
VITE_MOCK_MODE=false

# Hybrid: real PO list from Oracle; mock supplier/item lookups, line items, save/approve until DB delivers views/SPs
VITE_MOCK_PENDING=true
